# Скопируйте в .env при необходимости.

POSTGRES_IMAGE=postgres:16-alpine
MAVEN_IMAGE=maven:3.9-eclipse-temurin-17-alpine
JRE_IMAGE=eclipse-temurin:17-jre-alpine
NGINX_IMAGE=nginx:alpine

# Юридические реквизиты оператора (152-ФЗ) — обязательно перед prod
# APP_LEGAL_OPERATOR_NAME=Иванов Иван Иванович
# APP_LEGAL_OPERATOR_INN=123456789012
# APP_LEGAL_OPERATOR_OGRN=   # только для ИП/ООО, у физлица не заполняется
# APP_LEGAL_OPERATOR_ADDRESS=123456, г. Москва, ул. Примерная, д. 1
# APP_LEGAL_PRIVACY_EMAIL=privacy@yourdomain.ru
# APP_LEGAL_SUPPORT_EMAIL=support@yourdomain.ru
# APP_LEGAL_SITE_URL=https://yourdomain.ru
# APP_LEGAL_POLICY_VERSION=2026-06-26
# APP_LEGAL_TERMS_VERSION=2026-06-26

# Зеркала Docker Hub (если нужны):
# POSTGRES_IMAGE=dockerhub.timeweb.cloud/library/postgres:16-alpine
